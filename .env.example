# Backend API
PORT=4000
JWT_SECRET=replace-with-a-strong-secret

# Any signup with this email becomes admin
ADMIN_EMAIL=admin@xops.club

# Admin password for production (Vercel). Keep secret and set in Vercel env vars.
ADMIN_PASSWORD=replace-with-a-strong-password

# Vercel Blob (optional). If set, images are stored permanently in Vercel Blob.
# Create a Blob store in Vercel → Storage → Blob, then add this env var.
BLOB_READ_WRITE_TOKEN=
